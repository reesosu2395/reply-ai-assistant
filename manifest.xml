<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp
  xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:mailappor="http://schemas.microsoft.com/office/mailappversionoverrides/1.0"
  xsi:type="MailApp">

  <!-- ═══════════════════════════════════════════════
       IDENTITY
  ════════════════════════════════════════════════ -->
  <Id>a1b2c3d4-e5f6-7890-abcd-ef1234567890</Id>  <!-- Replace with a real GUID: https://www.guidgenerator.com -->
  <Version>1.0.0.0</Version>
  <ProviderName>Gemini Coatings</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>

  <DisplayName DefaultValue="AI Reply Assistant" />
  <Description DefaultValue="Generate 4 context-aware reply options using Claude AI." />

  <!-- ═══════════════════════════════════════════════
       ICON ASSETS
       Replace URLs with your Cloudflare Pages URLs
  ════════════════════════════════════════════════ -->
  <IconUrl DefaultValue="https://your-pages-domain.pages.dev/assets/icon-80.png" />
  <HighResolutionIconUrl DefaultValue="https://your-pages-domain.pages.dev/assets/icon-128.png" />
  <SupportUrl DefaultValue="https://your-pages-domain.pages.dev/support" />

  <!-- ═══════════════════════════════════════════════
       PERMISSIONS & HOST
  ════════════════════════════════════════════════ -->
  <Permissions>ReadWriteItem</Permissions>

  <Hosts>
    <Host Name="Mailbox" />
  </Hosts>

  <Requirements>
    <Sets>
      <Set Name="Mailbox" MinVersion="1.3" />
    </Sets>
  </Requirements>

  <!-- ═══════════════════════════════════════════════
       LEGACY FORM FACTORS (Outlook 2016 / Classic)
  ════════════════════════════════════════════════ -->
  <FormSettings>
    <Form xsi:type="ItemRead">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://your-pages-domain.pages.dev/taskpane.html" />
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
    <Form xsi:type="ItemEdit">
      <DesktopSettings>
        <SourceLocation DefaultValue="https://your-pages-domain.pages.dev/taskpane.html" />
        <RequestedHeight>450</RequestedHeight>
      </DesktopSettings>
    </Form>
  </FormSettings>

  <!-- ═══════════════════════════════════════════════
       VERSION OVERRIDES (Modern Outlook / New UI)
  ════════════════════════════════════════════════ -->
  <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides" xsi:type="VersionOverridesV1_0">
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/mailappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">

      <Requirements>
        <bt:Sets DefaultMinVersion="1.3">
          <bt:Set Name="Mailbox" />
        </bt:Sets>
      </Requirements>

      <Hosts>
        <Host xsi:type="MailHost">
          <DesktopFormFactor>

            <!-- ── Source file for task pane ─────────── -->
            <FunctionFile resid="Commands.Url" />

            <!-- ══════════════════════════════════════════
                 MESSAGE READ: shows button in reading pane
            ═════════════════════════════════════════════ -->
            <ExtensionPoint xsi:type="MessageReadCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgReadGroup">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="msgReadOpenPaneButton">
                    <Label resid="TaskpaneButton.Label" />
                    <Supertip>
                      <Title resid="TaskpaneButton.Label" />
                      <Description resid="TaskpaneButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <TaskpaneId>ButtonId1</TaskpaneId>
                      <SourceLocation resid="Taskpane.Url" />
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

            <!-- ══════════════════════════════════════════
                 MESSAGE COMPOSE: shows button while writing
            ═════════════════════════════════════════════ -->
            <ExtensionPoint xsi:type="MessageComposeCommandSurface">
              <OfficeTab id="TabDefault">
                <Group id="msgComposeGroup">
                  <Label resid="GroupLabel" />
                  <Control xsi:type="Button" id="msgComposeOpenPaneButton">
                    <Label resid="TaskpaneButton.Label" />
                    <Supertip>
                      <Title resid="TaskpaneButton.Label" />
                      <Description resid="TaskpaneButton.Tooltip" />
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16" />
                      <bt:Image size="32" resid="Icon.32x32" />
                      <bt:Image size="80" resid="Icon.80x80" />
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <TaskpaneId>ButtonId2</TaskpaneId>
                      <SourceLocation resid="Taskpane.Url" />
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>

          </DesktopFormFactor>
        </Host>
      </Hosts>

      <!-- ═══════════════════════════════════════════
           SHARED RESOURCES
      ════════════════════════════════════════════ -->
      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://your-pages-domain.pages.dev/assets/icon-16.png" />
          <bt:Image id="Icon.32x32" DefaultValue="https://your-pages-domain.pages.dev/assets/icon-32.png" />
          <bt:Image id="Icon.80x80" DefaultValue="https://your-pages-domain.pages.dev/assets/icon-80.png" />
        </bt:Images>
        <bt:Urls>
          <bt:Url id="Commands.Url"  DefaultValue="https://your-pages-domain.pages.dev/commands.html" />
          <bt:Url id="Taskpane.Url" DefaultValue="https://your-pages-domain.pages.dev/taskpane.html" />
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GroupLabel"            DefaultValue="AI Assistant" />
          <bt:String id="TaskpaneButton.Label"  DefaultValue="AI Reply Assistant" />
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="TaskpaneButton.Tooltip"
            DefaultValue="Open AI Reply Assistant to generate smart reply options for this email." />
        </bt:LongStrings>
      </Resources>

    </VersionOverrides>
  </VersionOverrides>

</OfficeApp>
